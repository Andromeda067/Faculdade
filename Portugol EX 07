programa
{
    inteiro vetor[10]
    inteiro i
    
    funcao inicio()
    {
        para (i = 0; i < 10; i++) {
            escreva("Digite o ", i+1, "º número: ")
            leia(vetor[i])
        }

        escreva("Vetor em ordem inversa: ")
        para (i = 9; i >= 0; i--) {
            escreva(vetor[i], " ")
        }
    }
}
