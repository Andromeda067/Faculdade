programa {
  inteiro soma_positivos, contador, numero
  funcao inicio() {
      soma_positivos = 0
      
      para(contador = 1; contador<= 10; contador++ ){
        escreva("Digite O ",contador,"º número: ")
        leia(numero)

        se(numero > 0){
          soma_positivos = soma_positivos + numero
        }

      }
      escreva("A Soma dos numeros positivos e: ",soma_positivos)
    }
  }

